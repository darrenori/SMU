{
  "manifest_version": 3,
  "name": "IKEBOT",
  "description": "Private, deterministic legal workflow tools for lawyers in Singapore.",
  "version": "2.0.0",
  "action": {
    "default_title": "Open IKEBOT",
    "default_popup": "extension/popup.html"
  },
  "icons": {
    "16": "content/2.png",
    "32": "content/2.png",
    "48": "content/2.png",
    "128": "content/2.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
